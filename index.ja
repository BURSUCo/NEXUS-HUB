import express from "express";
const app = express();
const PORT = process.env.PORT || 10000;

app.get("/script", (req, res) => {
  // AICI pui TOT codul tău Lua
  const lua = `
print("NEXUS HUB LOADED")

-- ===== LIBRARY =====
local AlchemyLib = {}
function AlchemyLib:Hello()
    print("Hello from Library")
end

-- ===== MAIN =====
AlchemyLib:Hello()
`;

  res.send(lua);
});

app.listen(PORT, () => {
  console.log("Server running");
});
